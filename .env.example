# 기본 템플릿 (권장: .env.local / .env.production 분리 사용)
# 로컬 테스트: .env.local
# 프로덕션 빌드: .env.production

# 실기기 로컬 테스트: API_BASE_URL=http://<Mac LAN IP>:3000
# 에뮬레이터 로컬 테스트: API_BASE_URL=http://10.0.2.2:3000
API_BASE_URL=http://10.0.2.2:3000

# Kakao Developers (https://developers.kakao.com)
KAKAO_APP_KEY=
KAKAO_REST_API_KEY=
KAKAO_JS_KEY=

# Naver Cloud Platform (https://console.ncloud.com) — Maps API
NAVER_MAP_CLIENT_ID=
NAVER_MAP_CLIENT_SECRET=

# Naver Developers (https://developers.naver.com) — Search API (장소 검색)
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
